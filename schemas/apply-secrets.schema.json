{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/feishu-agent-ops/apply-secrets.schema.json",
  "title": "Feishu Agent Ops Apply Secrets Map",
  "type": "object",
  "required": ["accounts"],
  "properties": {
    "accounts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/accountSecret"
      }
    }
  },
  "$defs": {
    "accountSecret": {
      "type": "object",
      "required": ["appSecret"],
      "properties": {
        "appSecret": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
